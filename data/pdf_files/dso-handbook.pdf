            <div class="field field--name-body field--type-text-with-summary field--label-hidden field__item"><div class="raw-html-embed">
                    
                
            
        
    <div class="grid-row grid-gap">
                                          
                                        
                                
                        
                
        <div class="grid-col-6">
                                                                
                                                            
                                                
                                    
                        
            <p>
                                                                                 <img src="/sites/default/files/images/eroRightBlock_2.jpg" alt="ICE ERO" width="100%" height="100%"> 
                                                                            
                                                            
                                            
                            
            </p>
                                                                
                                                            
                                                
                                    
                        
            <h4>
                                                                                 How ICE Enforces Immigration Laws 
                                                                            
                                                            
                                            
                            
            </h4>
                                                                
                                                            
                                                
                                    
                        
            <p>
                                                                                 ICE identifies and apprehends removable aliens, detains these individuals and removes illegal aliens from the United States. 
                                                                            
                                                            
                                            
                            
            </p>
                                                                
                                                            
                                                
                                    
                        
            <p>
                                                                                 <a class="learnmore" href="/about-ice/ero" style="white-space: normal;">Learn more 
                                                                                      about ERO</a> 
                                                                            
                                                            
                                            
                            
            </p>
                                                            	
                                                        
                                            
                                
                    
        </div>
                                            
                                        
                                        
                                
                        
                
        <div class="grid-col-6">
                                                                
                                                
                                    
                        
            <p>
                                                                                 <img src="https://www.ice.gov/sites/default/files/migrated/images/eFileBanner.jpg" alt="ICE ERO" width="100%" height="auto" style="aspect-ratio: 107/80;     object-fit: cover; object-position: right; filter: grayscale(1);"> 
                                                                            
                                                            
                                            
                            
            </p>
                                                            
                                                
                                    
                        
            <h4>
                                                                                 ICE Check-in 
                                                                            
                                                            
                                            
                            
            </h4>
                                                                
                                                            
                                                
                                    
                        
            <p>
                                                                                 <a class="learnmore" href="/check-in" style="white-space: normal;">Learn more about 
                                                                                      how to check in 
                                                                                      with a local 
                                                                                      ICE office</a> 
                                                                            
                                                            
                                            
                            
            </p>
                                                                <!--p>
                                                                        Get information about how to check in with your local ICE Office <a href="/check-in" title="ICE Check-in">here</a>.
                                                                    </p-->
                                                       
                                                                  
                                                            
                                                
                                    
                        
            <h4>
                                                                                 ERO <b style="text-transform:none">e</b>File 
                                                                            
                                                            
                                            
                            
            </h4>
                                                                  
                                                            
                                                
                                    
                        
            <p>
                                                                                 A uniform platform for the filing of electronic G-28s with ERO and the scheduling of legal visits through ERO eFile’s Detention Facility Appointment Scheduler (DFAS).
                                                                            
                                                            
                                            
                            
            </p>
                                                            
                                                
                                    
                        
            <p>
                                                                                 <a class="learnmore" href="/eroefile">Learn more about<br>
                                                                                ERO eFile</a> 
                                                                            
                                                            
                                            
                            
            </p>
                                                                
                                                        
                                            
                                
                    
        </div>
                                          
                                    
                            
                    
            
    </div>
</div></div>
      
  </div>
</div></div>

</div>

</div>

  </div>
</div>
